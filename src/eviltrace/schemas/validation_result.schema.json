{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvilTrace Validation Result",
  "type": "object",
  "required": ["finding_id", "status", "confidence", "corroborated_by", "contradicted_by", "unsupported_claims", "hallucination_check", "recommended_status", "reason"],
  "properties": {
    "finding_id": {"type": "string"},
    "status": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "corroborated_by": {"type": "array", "items": {"type": "string"}},
    "contradicted_by": {"type": "array", "items": {"type": "string"}},
    "unsupported_claims": {"type": "array", "items": {"type": "string"}},
    "hallucination_check": {"type": "string", "enum": ["passed", "failed"]},
    "recommended_status": {"type": "string"},
    "reason": {"type": "string"}
  }
}

