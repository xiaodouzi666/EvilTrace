{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvilTrace Audit Event",
  "type": "object",
  "required": ["event_id", "run_id", "case_id", "iteration", "timestamp_utc", "event_type", "actor", "input", "output_summary", "token_usage", "cost_usd", "status"],
  "properties": {
    "event_id": {"type": "string"},
    "run_id": {"type": "string"},
    "case_id": {"type": "string"},
    "iteration": {"type": "integer", "minimum": 0},
    "timestamp_utc": {"type": "string"},
    "event_type": {"type": "string"},
    "actor": {"type": "string"},
    "mcp_tool": {"type": ["string", "null"]},
    "input": {"type": "object"},
    "output_summary": {"type": "object"},
    "audit_id": {"type": ["string", "null"]},
    "token_usage": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "total_tokens"],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0}
      }
    },
    "cost_usd": {"type": "number", "minimum": 0},
    "status": {"type": "string"}
  }
}

