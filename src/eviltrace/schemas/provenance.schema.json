  "type": "object",
  "required": ["provenance_id", "audit_id", "case_id", "source_path", "source_sha256", "tool_layer", "mcp_tool", "timestamp_utc", "stdout_sha256", "stderr_sha256", "exit_code", "duration_ms"],
  "properties": {
