    "case_id": {"type": "string"},
    "evidence_id": {"type": "string"},
    "source_path": {"type": "string"},
    "source_sha256": {"type": "string"},
    "tool_layer": {"type": "string"},
    "mcp_tool": {"type": "string"},
    "underlying_tool": {"type": "string"},
    "command_template": {"type": "string"},
    "command_redacted": {"type": "string"},
    "timestamp_utc": {"type": "string"},
    "stdout_sha256": {"type": "string"},
    "stderr_sha256": {"type": "string"},
    "raw_output_path": {"type": "string"},
    "exit_code": {"type": "integer"},
    "duration_ms": {"type": "integer", "minimum": 0}
