{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvilTrace Artifact",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "source_path", "source_sha256", "mcp_tool", "audit_id"],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^artifact-[0-9]{4}$"},
    "artifact_type": {"type": "string"},
    "source_path": {"type": "string"},
    "source_sha256": {"type": "string"},
    "tool": {"type": "string"},
    "mcp_tool": {"type": "string"},
    "audit_id": {"type": "string", "pattern": "^audit-[0-9]{6}$"},
    "offset_or_record": {"type": ["string", "null"]},
    "raw_output_path": {"type": ["string", "null"]},
    "summary": {"type": "object"}
  }
}

